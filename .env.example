# ── Banco central (tenant registry) ──────────────────────────────
# Variáveis separadas evitam problemas de escape de caracteres
# especiais na senha (ex: @, ;, /, {, }, +, =)
DB_HOST=
DB_PORT=3306
DB_USER=appuser
DB_PASSWORD=
DB_NAME=LS
# ── Redis (BullMQ) ────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

LOG_DB_URL=mysql://app_user:ToddyTabitaDanteUnai@2026@10.108.0.6:3306/LS_INGESTOR_LOGS

# ── API ───────────────────────────────────────────────────────────
PORT=3000

# ── Worker ───────────────────────────────────────────────────────
# Quantos jobs o worker processa em paralelo
WORKER_CONCURRENCY=5

# ── Bull Board (monitoramento de filas) ──────────────────────────
BOARD_ENABLED=true
BOARD_PATH=/board
BOARD_USER=admin
BOARD_PASS=admin123
