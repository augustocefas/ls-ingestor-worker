# ── Banco central (tenant registry) ──────────────────────────────
# Escolha UM dos dois abaixo:
#DB_PROVIDER=postgresql          # postgresql | mysql

#DB_PROVIDER=mysql  
# PostgreSQL
# CENTRAL_DB_URL=postgresql://user:password@localhost:5432/central_db

# MySQL (descomente se usar MySQL)
CENTRAL_DB_URL=mysql://cefas:%40%40ldk36n@localhost:3306/LS

# ── Redis (BullMQ) ────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

LOG_DB_URL=mysql://cefas:%40%40ldk36n@localhost:3306/LS_INGESTOR_LOGS

# ── API ───────────────────────────────────────────────────────────
PORT=3000

# ── Worker ───────────────────────────────────────────────────────
# Quantos jobs o worker processa em paralelo
WORKER_CONCURRENCY=5

# ── Bull Board (monitoramento de filas) ──────────────────────────
BOARD_ENABLED=true
BOARD_PATH=/board
BOARD_USER=admin
BOARD_PASS=admin123
