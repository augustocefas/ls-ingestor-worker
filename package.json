{
  "name": "telemetry-ingest",
  "version": "1.0.0",
  "description": "Telemetry CSV ingest service — multi-tenant, BullMQ queue",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma && prisma generate --schema=prisma/log.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:log:migrate": "prisma migrate dev --schema=prisma/log.prisma"
  },
  "dependencies": {
    "@bull-board/api": "^5.21.0",
    "@bull-board/express": "^5.21.0",
    "@prisma/client": "^5.13.0",
    "@types/dotenv": "^6.1.1",
    "bullmq": "^5.7.0",
    "csv-parse": "^5.5.6",
    "dotenv": "^17.4.0",
    "express": "^4.19.2",
    "ioredis": "^5.3.2",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "prisma": "^5.13.0",
    "tsx": "^4.8.2",
    "typescript": "^5.4.5"
  }
}
